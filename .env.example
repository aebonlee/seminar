# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PortOne (카드결제)
VITE_PORTONE_STORE_ID=your-store-id
VITE_PORTONE_CHANNEL_KEY=your-channel-key

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Kakao OAuth
VITE_KAKAO_CLIENT_ID=your-kakao-client-id

# Site URL (배포 도메인)
VITE_SITE_URL=https://seminar.dreamitbiz.com

# Resend (이메일 알림 - 옵션)
VITE_RESEND_API_KEY=your-resend-api-key

# 관리자 이메일 (콤마 구분, 클라이언트 식별용 — 실제 권한은 Supabase RLS로 강제)
VITE_ADMIN_EMAILS=admin@dreamitbiz.com
