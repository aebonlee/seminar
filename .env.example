# ============================================================
# DreamIT Seminar — Environment Configuration
# (templete_2 표준 + 알림/관리자 확장)
# ============================================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PortOne (카드결제)
VITE_PORTONE_STORE_ID=your-store-id
VITE_PORTONE_CHANNEL_KEY=your-channel-key

# Google OAuth (Supabase Auth Provider 활성화 필요)
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Kakao OAuth (Supabase Auth Provider 활성화 필요)
VITE_KAKAO_CLIENT_ID=your-kakao-client-id

# Site URL (배포 도메인 — OG, OAuth redirect에 사용)
VITE_SITE_URL=https://seminar.dreamitbiz.com

# Resend (이메일 알림 — Supabase Edge Function 'send-email' 에 환경변수로 설정,
#          클라이언트에는 노출하지 마세요)
# VITE_RESEND_API_KEY=  (사용 안 함 — Edge Function 비밀로만)

# 관리자 이메일 (콤마 구분, 클라이언트 UI 노출용 — 실제 권한은 Supabase RLS의 seminar_is_admin() 으로 강제)
VITE_ADMIN_EMAILS=admin@dreamitbiz.com
